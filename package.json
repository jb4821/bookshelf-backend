{
  "name": "bookshelf-backend",
  "version": "1.0.0",
  "description": "Daily Book Insights Wallpaper App — Backend API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec \"node --experimental-strip-types\" src/server.js",
    "dev:neon": "nodemon --exec \"dotenv -e .env.neon -- node --experimental-strip-types\" src/server.js",
    "start": "node --experimental-strip-types src/server.js",
    "seed": "node --experimental-strip-types prisma/seed.js",
    "seed:neon": "dotenv -e .env.neon -- node --experimental-strip-types prisma/seed.js",
    "migrate": "npx prisma migrate dev",
    "migrate:neon": "dotenv -e .env.neon -- npx prisma migrate dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jb4821/bookshelf-backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jb4821/bookshelf-backend/issues"
  },
  "homepage": "https://github.com/jb4821/bookshelf-backend#readme",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1010.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "canvas": "^3.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "google-translate-api-x": "^10.7.2",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.5.0"
  }
}
