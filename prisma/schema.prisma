generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────

model User {
  id                String   @id @default(uuid())
  phone             String   @unique
  name              String?
  email             String?
  preferredLanguage String   @default("en") @map("preferred_language")
  notifications     Json     @default("{\"dailyReminder\": true, \"newBooks\": true}")
  role              Role     @default(USER)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  purchases  Purchase[]
  activeBook ActiveBook?
  quoteReads UserQuoteRead[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// ─── Categories ──────────────────────────────────────

model Category {
  id   String @id @default(uuid())
  name String @unique

  books Book[]

  @@map("categories")
}

// ─── Books ───────────────────────────────────────────

model Book {
  id                String            @id @default(uuid())
  title             String
  author            String?
  description       String?
  categoryId        String            @map("category_id")
  coverImage        String?           @map("cover_image")
  price             Decimal           @default(0) @db.Decimal(10, 2)
  rating            Decimal?          @db.Decimal(2, 1)
  totalQuotes       Int               @default(0) @map("total_quotes")
  totalPages        Int?              @map("total_pages")
  publishedYear     Int?              @map("published_year")
  tags              Json?
  isActive          Boolean           @default(true) @map("is_active")
  translationStatus TranslationStatus @default(NONE) @map("translation_status")
  createdAt         DateTime          @default(now()) @map("created_at")

  category   Category        @relation(fields: [categoryId], references: [id])
  contents   BookContent[]
  purchases  Purchase[]
  quoteReads UserQuoteRead[]

  @@map("books")
}

enum TranslationStatus {
  NONE
  IN_PROGRESS
  COMPLETED
  FAILED
}

// ─── Book Contents ───────────────────────────────────

model BookContent {
  id            String   @id @default(uuid())
  bookId        String   @map("book_id")
  chapterNumber Int      @map("chapter_number")
  chapterTitle  String?  @map("chapter_title")
  quoteIndex    Int      @map("quote_index")
  quotes             Json     // { "en": "...", "hi": "..." }
  descriptions       Json     // { "en": "...", "hi": "..." }
  deepDives          Json?    @map("deep_dives")          // { "en": "...", "hi": "..." }
  realWorldExamples  Json?    @map("real_world_examples") // { "en": "...", "hi": "..." }
  createdAt     DateTime @default(now()) @map("created_at")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, quoteIndex])
  @@map("book_contents")
}

// ─── Purchases ───────────────────────────────────────

model Purchase {
  id            String         @id @default(uuid())
  userId        String         @map("user_id")
  bookId        String         @map("book_id")
  durationDays  Int            @map("duration_days")
  purchaseToken String?        @map("purchase_token")
  platform      Platform?
  startDate     DateTime       @map("start_date") @db.Date
  endDate       DateTime       @map("end_date") @db.Date
  status        PurchaseStatus @default(ACTIVE)
  createdAt     DateTime       @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id])
  book       Book        @relation(fields: [bookId], references: [id])
  activeBook ActiveBook?

  @@index([userId, status])
  @@map("purchases")
}

enum Platform {
  GOOGLE_PLAY
  APP_STORE
}

enum PurchaseStatus {
  ACTIVE
  EXPIRED
  REFUNDED
}

// ─── Active Books ────────────────────────────────────

model ActiveBook {
  userId     String   @id @map("user_id")
  purchaseId String   @unique @map("purchase_id")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id])
  purchase Purchase @relation(fields: [purchaseId], references: [id])

  @@map("active_books")
}

// ─── User Quote Reads ───────────────────────────────

model UserQuoteRead {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  bookId     String   @map("book_id")
  quoteIndex Int      @map("quote_index")
  readAt     DateTime @default(now()) @map("read_at")

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId, quoteIndex])
  @@map("user_quote_reads")
}

// ─── Templates ───────────────────────────────────────

model Template {
  id        String   @id @default(uuid())
  name      String
  s3Key     String   @map("s3_key")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("templates")
}
